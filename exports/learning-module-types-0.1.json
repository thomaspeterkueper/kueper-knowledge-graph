    {
      "id": "LMT:grundmodul",
      "type": "LearningModuleType",
      "value": "grundmodul",
      "description": "Foundation module with no or minimal prerequisites; introduces a core knowledge area."
    },
    {
      "id": "LMT:brueckenmodul",
      "type": "LearningModuleType",
      "value": "brueckenmodul",
      "description": "Bridge module connecting foundation modules to higher-level domains or applied modules."
    },
    {
      "id": "LMT:archivmodul",
      "type": "LearningModuleType",
      "value": "archivmodul",
      "description": "Module leading a learner toward reading a specific source document. The source document may belong to any registered document source."
    },
    {
      "id": "LMT:reference",
      "type": "LearningModuleType",
      "value": "reference",
      "description": "Reference-oriented module for a specific method, concept or prerequisite."
    },
    {
      "id": "LMT:learning_path",
      "type": "LearningModuleType",
      "value": "learning_path",
      "description": "Path-like module grouping a sequence or thematic branch."
    },
    {
      "id": "LMT:experiment",
      "type": "LearningModuleType",
      "value": "experiment",
      "description": "Module centered on an experiment, observation, simulation or applied activity."
    }
  ],
