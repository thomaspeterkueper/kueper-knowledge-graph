{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KUEPER Knowledge Graph Entity",
  "type": "object",
  "required": ["entity_id", "typ", "name", "domäne", "status", "beschreibung", "erstellt", "kurator"],
  "properties": {
    "entity_id": { "type": "string" },
    "typ": { "enum": ["Concept", "Person", "Place", "Technology", "Event", "Organization", "Document", "Universe", "LearningModule", "Model"] },
    "name": { "type": "string" },
    "name_en": { "type": "string" },
    "domäne": { "type": "string" },
    "layer": { "enum": ["L0", "L1", "L2", "L3", "L4"] },
    "status": { "enum": ["[R]", "[T]", "[H]", "[S]", "[F]", "[I]", "[W]", "[OFFEN]"] },
    "is_instance": { "type": "boolean" },
    "instance_of": { "type": "string" },
    "foundation_node": { "type": "boolean" },
    "bridge_node_candidate": { "type": "boolean" },
    "schichten": { "type": "array", "items": { "enum": ["KUEPER", "SSF", "OTA", "NOXIA", "SOURCE"] } },
    "beschreibung": { "type": "string" },
    "function": { "type": "string" },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "relation": { "type": "string" },
          "target": { "type": "string" }
        }
      }
    },
    "derived_from": { "type": "array", "items": { "type": "string" } },
    "enables": { "type": "array", "items": { "type": "string" } },
    "erster_nachweis": { "type": "string" },
    "erstellt": { "type": "string" },
    "kurator": { "type": "string" }
  }
}
